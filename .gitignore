# Models
model/

# Patient video data (never commit): the videos/ session tree, plus any
# stray clip anywhere in the tree (e.g. dropped in the project root). Globs
# are case-folded so .MP4 / .mp4 / .Mov etc. all match.
videos
*.[mM][pP]4
*.[mM][oO][vV]
*.[aA][vV][iI]
*.[mM][kK][vV]
*.[mM]4[vV]
*.[wW][mM][vV]
*.[wW][eE][bB][mM]

# Pose estimation output (never commit)
output
benchmark_output

# Camera calibration (patient-adjacent: identifying lab/rig geometry — never commit)
calibration/
calibration.json

# Secrets / credentials (safety net)
.env
.env.*
*.env

# OS
.DS_Store
Thumbs.db

# Posit
.positai/

# Logs (may capture session/patient paths)
*.log

# MediaPipe downloaded models
mediapipe/

# Serena (Headroom): .serena/ self-governs via .serena/.gitignore — cache + project.local.yml local, project.yml + .gitignore committed; memory disabled globally, so memories/ stays empty.

