# direnv: select uv's per-layer project venv by the path the working tree is
# accessed at — the ground truth for which venv's hardcoded absolute paths resolve.
# The Debian Distrobox container sees the host tree under /run/host/...; the
# openSUSE host sees it at its own path (no /run/host prefix). A venv built for one
# layer is invalid at the other, so a bare `uv sync` against the wrong venv rebuilds
# (clobbers) it: the original footgun was a host `uv` overwriting the container's
# .venv with host paths, breaking in-container `import pose_estimation`; the reverse
# is symmetric. Keying on the /run/host prefix — not /run/.containerenv, which
# Podman omits when /run is volume-mounted — stays correct in both directions, and
# survives a /home -> /var/home symlink (the prefix is preserved either way).
# direnv acts only in an allowed, hooked, interactive shell; elsewhere (scripts,
# cron, fresh shells, before `direnv allow`) export UV_PROJECT_ENVIRONMENT yourself.
# See .claude/tech/environment.md "Host-side runs".
case "$PWD" in
  /run/host/*) export UV_PROJECT_ENVIRONMENT=.venv ;;       # in-container (canonical; uv's default)
  *)           export UV_PROJECT_ENVIRONMENT=.venv-host ;;  # host (e.g. NPU runs)
esac
