# direnv: auto-select uv's per-layer project venv so a bare `uv` can't clobber
# the other layer's environment. Prior footgun: a forgotten manual export made a
# host `uv sync` rebuild the container's .venv with host /home/... paths, silently
# breaking in-container `import pose_estimation`. Distrobox/Podman containers carry
# /run/.containerenv; the openSUSE host has no such marker. See
# .claude/tech/environment.md "Host-side runs".
if [ -e /run/.containerenv ] || [ -e /.dockerenv ]; then
  export UV_PROJECT_ENVIRONMENT=.venv        # in-container (canonical; matches uv's default)
else
  export UV_PROJECT_ENVIRONMENT=.venv-host   # openSUSE host (e.g. NPU runs)
fi
